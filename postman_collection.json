		{
			"name": "Amenities",
			"item": [
				{
					"name": "List Amenities (Grouped)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Domain",
								"value": "{{domainSlug}}"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/amenities",
							"host": ["{{baseUrl}}"],
							"path": ["amenities"]
						},
						"description": "All active amenities grouped by category."
					},
					"response": []
				}
			]
		},
		{
			"name": "Error Tests",
			"item": [
				{
					"name": "Missing X-Domain Header → 400",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/hotels",
							"host": ["{{baseUrl}}"],
							"path": ["hotels"]
						},
						"description": "Test: calling without X-Domain header should return 400."
					},
					"response": []
				},
				{
					"name": "Invalid Domain Slug → 404",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Domain",
								"value": "non-existent-domain"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/hotels",
							"host": ["{{baseUrl}}"],
							"path": ["hotels"]
						},
						"description": "Test: invalid domain slug should return 404."
					},
					"response": []
				}
			]
		}
	]
}
